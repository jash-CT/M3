# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=fintech
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_PREFIX=fintech:

# JWT (use strong secrets in production)
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Idempotency (TTL in seconds for idempotency keys)
IDEMPOTENCY_TTL_SECONDS=86400

# Partner gateway
PARTNER_API_KEY_HEADER=X-API-Key
PARTNER_WEBHOOK_SECRET=

# Fraud
FRAUD_THRESHOLD=0.7
FRAUD_RULES_CACHE_TTL=300
